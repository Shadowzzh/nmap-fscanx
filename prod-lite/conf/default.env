# 第一阶段扫描端口。
# 目标 IP 只要命中这些端口中的任意一个，就会进入第二阶段全端口扫描。
NMAP_FSCANX_PHASE1_PORTS=22,80,443,445,3389

# 第二阶段扫描端口范围。
# 默认对第一阶段命中的主机执行全端口扫描。
NMAP_FSCANX_PHASE2_PORTS=1-65535

# fscanx 并发数。
# 数值越大扫描越快，但也会增加本机和目标网络压力。
NMAP_FSCANX_THREADS=4000

# 单次端口探测超时时间，单位为秒。
# 内网延迟较低时可保持默认值，网络较慢时可适当调大。
NMAP_FSCANX_TIMEOUT=1

# tmux 会话名前缀。
# 使用 start 命令后台启动扫描时，会用这个前缀拼接会话名。
NMAP_FSCANX_TMUX_PREFIX=nmap-fscanx

# 调优说明：
# 提速优先看 NMAP_FSCANX_PHASE2_PORTS，其次再调 NMAP_FSCANX_THREADS。
# 端口范围越小通常越快；并发越高通常越快，但过高可能漏扫。
#
# 示例 1：默认折中
# NMAP_FSCANX_PHASE2_PORTS=1-65535
# NMAP_FSCANX_THREADS=4000
#
# 示例 2：优先完整性
# NMAP_FSCANX_PHASE2_PORTS=1-65535
# NMAP_FSCANX_THREADS=2000
#
# 示例 3：测试导表速度优先（推荐）
# NMAP_FSCANX_PHASE1_PORTS=22,80,443,445,3389
# NMAP_FSCANX_PHASE2_PORTS=22,80,81,88,110,111,135,139,143,161,389,443,445,465,587,631,873,993,995,1025,1080,1433,1521,2049,2181,2375,2379,3306,3389,5432,5601,5672,5900,6379,6443,7001,7002,8000,8001,8008,8080,8081,8088,8443,8888,9000,9042,9200,9300,11211,27017,50000
# NMAP_FSCANX_THREADS=4000
# NMAP_FSCANX_TIMEOUT=1
# 说明：适合时间有限、需要尽快导出测试资产表，同时尽量兼顾常见 Web、数据库和中间件端口的场景。
#
# 示例 4：优先速度
# NMAP_FSCANX_PHASE2_PORTS=1-1024
# NMAP_FSCANX_THREADS=4000
#
# 示例 5：更激进的速度优先
# NMAP_FSCANX_PHASE2_PORTS=1-1024
# NMAP_FSCANX_THREADS=8000
#
# 示例 6：极激进速度优先
# NMAP_FSCANX_PHASE2_PORTS=1-1024
# NMAP_FSCANX_THREADS=12000
# 说明：12000 更适合速度优先场景，建议先验证是否存在漏扫，再用于正式任务。
